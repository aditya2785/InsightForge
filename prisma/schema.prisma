generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String                @id @default(cuid())
  name         String
  email        String                @unique
  password     String
  createdAt    DateTime              @default(now())
  anomalies    Anomaly[]
  healthScores BusinessHealthScore[]
  forecasts    Forecast[]
  uploads      UploadedData[]
}

model UploadedData {
  id                   Int        @id @default(autoincrement())
  datasetType          String
  data                 Json
  userId               String
  createdAt            DateTime   @default(now())
  columnMapping        Json?
  compatibilityDetails Json?
  compatibilityScore   Int?
  anomalies            Anomaly[]
  forecasts            Forecast[]
  user                 User       @relation(fields: [userId], references: [id])
}

model BusinessHealthScore {
  id             String   @id @default(cuid())
  score          Int
  revenueScore   Int
  inventoryScore Int
  customerScore  Int
  forecastScore  Int
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

model Forecast {
  id              String       @id @default(cuid())
  forecastType    String
  predictionDate  DateTime
  predictedValue  Float
  confidenceScore Float
  userId          String
  datasetId       Int
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  dataset         UploadedData @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([forecastType])
  @@index([predictionDate])
  @@index([userId, forecastType, predictionDate])
}

model Anomaly {
  id          String       @id @default(cuid())
  anomalyType String
  title       String
  description String
  severity    String
  detectedAt  DateTime
  userId      String
  datasetId   Int
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  dataset     UploadedData @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([anomalyType])
  @@index([severity])
  @@index([userId, anomalyType, severity])
}
